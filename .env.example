# ============================================================
# TaxIQ — Environment Variables Template
# Copy this to .env and fill in your real API keys
# NEVER commit .env to version control
# ============================================================

# ----- LLM Provider (text generation) -----
# "groq" = LLaMA 3.3 70B via Groq (fast, recommended)
# "gemini" = Google Gemini 2.0 Flash
# "openai" = OpenAI GPT-4o
# "anthropic" = Anthropic Claude
LLM_PROVIDER=groq

# Groq (https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# OpenAI (optional)
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_MODEL=gpt-4o
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (optional)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ----- Embedding Provider -----
# Groq has no embedding API — use "gemini" (recommended) or "openai"
EMBEDDING_PROVIDER=gemini

# Web Search Integration (Phase 5)
TAVILY_API_KEY=

# ----- PostgreSQL (Phase 1+) -----
# Dev: docker compose up -d  (see docker-compose.yml)
# Prod: Supabase connection string (see SUPABASE_SETUP.md)
# Leave empty to keep using SQLite (legacy/dev fallback)
DATABASE_URL=postgresql+asyncpg://postgres:dev@localhost:5432/taxiq

# ----- Data Gateway -----
# direct = SQLAlchemy straight to Postgres (office / IPv6 networks)
# rest   = Supabase REST API (home / IPv4-only networks)
# auto   = probe direct, fall back to REST
# "direct" also auto-falls-back to REST when the DB is unreachable.
DB_ACCESS_MODE=auto
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Optional local LLM (OpenAI-compatible endpoint) -----
# Only used when a user's Settings > AI Model Mode is "local".
# Leave LOCAL_LLM_URL empty to disable entirely.
LOCAL_LLM_URL=
LOCAL_LLM_MODEL=qwen3.5-2b
LOCAL_LLM_API_KEY=
LOCAL_LLM_TIMEOUT=20

# ----- ChromaDB -----
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=rag_documents

# ----- Pipeline Settings -----
MAX_RETRIES=2
TOP_K_RETRIEVAL=10
TOP_K_RERANK=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ----- Conversation Memory -----
# "json" = JSON files on disk (original, no auth required)
# "postgres" = PostgreSQL messages table (Phase 1+, requires DATABASE_URL)
MEMORY_BACKEND=postgres
MEMORY_DIR=./data/memory
MAX_HISTORY_TOKENS=2000

# ----- FastAPI Server -----
HOST=0.0.0.0
PORT=8000
RELOAD=true

# ----- Document Ingestion -----
DOCUMENTS_DIR=./data/documents
MAX_UPLOAD_SIZE_MB=50

